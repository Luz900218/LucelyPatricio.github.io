{
    "name": "portfolio-tests",
    "version": "1.0.0",
    "description": "Testing suite for portfolio project",
    "scripts": {
        "test:unit": "jest --config jest.config.js",
        "test:schema": "node tests/schema.test.js",
        "test:e2e": "cypress run",
        "test:e2e:open": "cypress open",
        "test:all": "npm run test:schema && npm run test:unit && npm run test:e2e",
        "start": "http-server . -p 8080 -s"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "cypress": "^13.6.0",
        "ajv": "^8.12.0",
        "http-server": "^14.1.1"
    }
}
